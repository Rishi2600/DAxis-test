# ──────────────────────────────────────────────────────────
# DAxis Server — environment variables
# Copy this to `.env` and fill in real values
# ──────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Postgres connection string. Works with Neon, Railway, local Postgres, etc.
# Neon example:   postgresql://user:pass@ep-xxx.region.aws.neon.tech/daxis?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daxis

# Resend (https://resend.com) — OPTIONAL during local dev.
# If you leave this empty or remove the line, the form will still
# work (rows insert into the DB) but no email will be sent.
# Get a real key from your Resend dashboard when you're ready.
RESEND_API_KEY=

# Where the enquiry notification emails go
ADMIN_EMAIL=daxis.engg@gmail.com

# Verified sender in Resend (or use onboarding@resend.dev for testing)
EMAIL_FROM=DAxis Website <onboarding@resend.dev>

# CORS — must match the URL your frontend runs on
CORS_ORIGIN=http://localhost:5173

# Rate limit on the form endpoint
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5

# Admin dashboard credentials (used for /api/admin/*)
ADMIN_USER=admin
ADMIN_PASS=change-me-before-prod

# Cors
CORS_ORIGIN=